# tasks/deferred-writer/task.env — consumed by run-task.sh and grade-task.sh.
#
# PROFILE              which profiles/<name>.sh to source for this task
# PROBE_ARGS           appended to "/$CMD_NAME" during the behavioral probe
#                      (leading space intentional — we concatenate verbatim)
# PROBE_EVIDENCE_ANCHOR  recon-only; the writer probe hits the cancel path
#                      and has no content to anchor on.
PROFILE=writer
PROBE_ARGS=" create a file hello-probe.md with the text hi"

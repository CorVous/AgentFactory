# tasks/confined-drafter-agent/task.env
#
# Gate 2 proper: force the assembler to emit a confined-drafter-shaped
# extension so we can grep the output for cwd-guard wiring
# (`-e CWD_GUARD`, `PI_SANDBOX_ROOT`, `sandbox_write,sandbox_edit` in
# `--tools`). The behavior itself doesn't need to be graded; this task
# exists to surface live-composition evidence that the assembler
# actually wires cwd-guard into a generated agent, not just its
# pattern templates.
#
# No graded profile (writer's rubric is deferred-writer-specific); run
# without --grade and inspect artifacts/extensions/ by hand.
PROFILE=writer
PROBE_ARGS=""
PROBE_EVIDENCE_ANCHOR=

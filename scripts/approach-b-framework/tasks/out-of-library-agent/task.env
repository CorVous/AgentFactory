# tasks/out-of-library-agent/task.env — consumed by agent-maker.sh.
#
# This task is a GAP-FLAG probe for pi-agent-assembler: the prompt
# describes an agent shape the assembler's pattern catalog does NOT
# cover. Expected outcome when run with -s pi-agent-assembler:
#   - No .ts extension file is produced under artifacts/.
#   - events.ndjson contains the string "GAP:" (the assembler's
#     gap-flag template from procedure.md).
#
# Not intended for automated grading via grade-task.sh — no PROFILE
# matches "gap flag emission." Run as:
#   agent-maker.sh out-of-library-agent -m <model> -s pi-agent-assembler
# then inspect events.ndjson by hand.
#
# PROFILE is set for compatibility with run-task.sh / grade-task.sh
# dispatch; grading results will be meaningless on this task.
PROFILE=recon
PROBE_ARGS=""
PROBE_EVIDENCE_ANCHOR=

# tasks/recon-agent/task.env — consumed by run-task.sh and grade-task.sh.
#
# The probe points the recon agent at a stable fixture subdirectory of
# pi-sandbox (skills/pi-agent-builder/) and looks for SKILL.md as an
# anchor that proves the summary actually named real files it saw. The
# path is relative to pi-sandbox/ (pi's cwd during the probe).
PROFILE=recon
PROBE_ARGS=" skills/pi-agent-builder"
PROBE_EVIDENCE_ANCHOR=SKILL.md
